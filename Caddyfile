wavestack.duckdns.org {
    encode zstd gzip

    @static path /assets/* *.ico *.png *.jpg *.jpeg *.gif *.svg *.webp *.avif *.woff *.woff2
    header @static Cache-Control "public, max-age=31536000, immutable"

    @crawlerFiles path /robots.txt /sitemap.xml
    header @crawlerFiles Cache-Control "public, max-age=3600"

    @html path / /index.html
    header @html Cache-Control "no-cache"

    reverse_proxy frontend:5173 {
        header_down -Cache-Control
    }
}

api.wavestack.duckdns.org {
    encode zstd gzip

    reverse_proxy graphql-api:3000
}
