POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=wavestack
POSTGRES_USER=wavestack
POSTGRES_PASSWORD=wavestack_dev_password

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=wavestack_graph_password

RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

AUDIO_SERVICE_URL=http://audio-ai-service:8000
ANALYTICS_SERVICE_URL=http://analytics-service:8080

STORAGE_ACCOUNT=wavestackstorage
STORAGE_CONTAINER=tracks
SIGNED_URL_SECRET=replace-with-key-vault-secret
STREAM_TOKEN_TTL_SECONDS=900

# Google Drive public music library
GOOGLE_DRIVE_API_KEY=REPLACE-ME-WITH-GOOGLE-DRIVE-API-KEY
GOOGLE_DRIVE_FOLDER_IDS=REPLACE-ME-WITH-FOLDER-ID-1,REPLACE-ME-WITH-FOLDER-ID-2
API_PUBLIC_ORIGIN=http://localhost:3000

# Auth
JWT_SECRET=replace-with-output-from-openssl-rand-base64-64
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/google-drive-service-account.json
GOOGLE_DRIVE_PRIVATE_EXPORT_ENABLED=false
LISTENING_HABITS_GOOGLE_DRIVE_FOLDER_ID=TODO_FILL_LATER
GOOGLE_OAUTH_CLIENT_ID=replace-with-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=replace-with-google-oauth-client-secret
GOOGLE_OAUTH_CALLBACK_URL=https://api.example.com/auth/google/callback
FRONTEND_ORIGIN=https://app.example.com
DRIVE_TRACK_SYNC_THUMBNAIL_DIR=/app/.cache/thumbnails
DRIVE_TRACK_SYNC_THUMBNAIL_PUBLIC_PATH=/drive/assets/thumbnails
DRIVE_TRACK_SYNC_PAGE_SIZE=100
DASHBOARD_RECOMMENDATION_LIMIT=40

