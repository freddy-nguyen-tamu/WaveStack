python3 - <<'PY'
import json
import subprocess
import sys

location = "southcentralus"

preferred = [
    "Standard_B2ps_v2",
    "Standard_B2pls_v2",
    "Standard_D2ps_v5",
    "Standard_D2pls_v5",
    "Standard_D2ads_v6",
    "Standard_D2as_v6",
    "Standard_D2s_v6",
    "Standard_B1s",
    "Standard_B2s",
]

raw = subprocess.check_output([
    "az", "vm", "list-skus",
    "--location", location,
    "--resource-type", "virtualMachines",
    "--all",
    "-o", "json"
], text=True)

skus = json.loads(raw)

available = {}
for sku in skus:
    name = sku.get("name")
    restrictions = sku.get("restrictions") or []
    if not restrictions:
        caps = {c["name"]: c["value"] for c in sku.get("capabilities", [])}
        available[name] = caps

for name in preferred:
    if name in available:
        caps = available[name]
        arch = caps.get("CpuArchitectureType", "")
        vcpus = caps.get("vCPUs", "")
        mem = caps.get("MemoryGB", "")
        print(f"{name}|{arch}|{vcpus}|{mem}")
        sys.exit(0)

small = []
for name, caps in available.items():
    try:
        vcpus = int(float(caps.get("vCPUs", "999")))
    except ValueError:
        vcpus = 999
    if vcpus <= 2:
        small.append((name, caps.get("CpuArchitectureType", ""), vcpus, caps.get("MemoryGB", "")))

small.sort(key=lambda x: (x[2], x[0]))

if not small:
    print("NO_WORKING_SKU_FOUND")
    sys.exit(1)

name, arch, vcpus, mem = small[0]
print(f"{name}|{arch}|{vcpus}|{mem}")
PY

export SKU_INFO="$(python3 - <<'PY'
import json
import subprocess
import sys

location = "southcentralus"

preferred = [
    "Standard_B2ps_v2",
    "Standard_B2pls_v2",
    "Standard_D2ps_v5",
    "Standard_D2pls_v5",
    "Standard_D2ads_v6",
    "Standard_D2as_v6",
    "Standard_D2s_v6",
    "Standard_B1s",
    "Standard_B2s",
]

raw = subprocess.check_output([
    "az", "vm", "list-skus",
    "--location", location,
    "--resource-type", "virtualMachines",
    "--all",
    "-o", "json"
], text=True)

skus = json.loads(raw)
available = {}

for sku in skus:
    name = sku.get("name")
    restrictions = sku.get("restrictions") or []
    if not restrictions:
        caps = {c["name"]: c["value"] for c in sku.get("capabilities", [])}
        available[name] = caps

for name in preferred:
    if name in available:
        caps = available[name]
        print(f"{name}|{caps.get('CpuArchitectureType', 'x64')}")
        sys.exit(0)

for name, caps in sorted(available.items()):
    try:
        vcpus = int(float(caps.get("vCPUs", "999")))
    except ValueError:
        vcpus = 999
    if vcpus <= 2:
        print(f"{name}|{caps.get('CpuArchitectureType', 'x64')}")
        sys.exit(0)

raise SystemExit("No usable VM SKU found")
PY
