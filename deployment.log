from pathlib import Path

p = Path('docker-compose.yml')
s = p.read_text()

# Point frontend to HTTPS API domain.
s = s.replace(
    'VITE_GRAPHQL_URL: http://localhost:3000/graphql',
    'VITE_GRAPHQL_URL: https://api.wavestack.duckdns.org/graphql'
)
s = s.replace(
    'VITE_GRAPHQL_URL: http://${VM_PUBLIC_IP:-localhost}:3000/graphql',
    'VITE_GRAPHQL_URL: https://api.wavestack.duckdns.org/graphql'
)

# Remove any broken Caddy block accidentally inserted under volumes.
broken = '''  caddy:
    image: caddy:2
    ports:
      - \"80:80\"
      - \"443:443\"
    volumes:
      - ./Caddyfile:/etc/caddy/Caddyfile:ro
      - caddy-data:/data
      - caddy-config:/config
    depends_on:
      - frontend
      - graphql-api
'''
s = s.replace(broken, '')

# Add Caddy service before the top-level volumes section.
caddy_service = '''
  caddy:
    image: caddy:2
    ports:
      - \"80:80\"
      - \"443:443\"
    volumes:
      - ./Caddyfile:/etc/caddy/Caddyfile:ro
      - caddy-data:/data
      - caddy-config:/config
    depends_on:
      - frontend
      - graphql-api

'''

if '  caddy:' not in s.split('volumes:')[0]:
    s = s.replace('\\nvolumes:\\n', '\\n' + caddy_service + 'volumes:\\n')

# Add Caddy volumes correctly under top-level volumes.
if '  caddy-data:' not in s:
    s = s.replace('  neo4j-data:\\n', '  neo4j-data:\\n  caddy-data:\\n  caddy-config:\\n')

p.write_text(s)
