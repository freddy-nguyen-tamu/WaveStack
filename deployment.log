============================================================
ORACLE TERMINAL: START ONE DRIVE LIBRARY SYNC
============================================================

cd ~/WaveStack


# Do not start a second synchronization when one is already running.
if [ -s ~/wavestack-drive-sync.pid ] &&
   kill -0 "$(cat ~/wavestack-drive-sync.pid)" 2>/dev/null
then
  echo "Drive sync is already running with PID $(cat ~/wavestack-drive-sync.pid)"
else
  nohup curl -sS \
    https://api.wavestack.duckdns.org/graphql \
    -H 'Content-Type: application/json' \
    --data-binary '{
      "query": "mutation { syncDriveLibrary { ok message scannedCount upsertedCount thumbnailCount } }"
    }' \
    > ~/wavestack-drive-sync.log \
    2>&1 &

  echo $! |
  tee ~/wavestack-drive-sync.pid

  echo 'Drive synchronization started.'
fi


# Do not restart graphql-api or run docker compose down during this sync.


============================================================
ORACLE TERMINAL: CHECK DRIVE SYNC
============================================================

# Check whether the background curl process is alive.
if [ -s ~/wavestack-drive-sync.pid ]; then
  ps -p "$(cat ~/wavestack-drive-sync.pid)" \
    -o pid,etime,cmd ||
  true
else
  echo 'No Drive sync PID file exists.'
fi


# Lightweight application status query.
curl -sS \
  https://api.wavestack.duckdns.org/graphql \
  -H 'Content-Type: application/json' \
  --data-binary '{
    "query": "{ driveSyncStatus { status startedAt finishedAt scannedCount upsertedCount thumbnailCount errorMessage } }"
  }' |
jq .


# Database progress.
cd ~/WaveStack

sudo docker compose exec -T postgres \
  psql \
  -U wavestack \
  -d wavestack \
  -c "
    SELECT
      count(*) AS total_tracks,
      count(*) FILTER (
        WHERE title_locked = true
      ) AS metadata_checked,
      count(*) FILTER (
        WHERE local_thumbnail_url IS NOT NULL
      ) AS thumbnails_cached
    FROM drive_tracks
    WHERE deleted_at IS NULL;
  "


# Recent synchronization logs.
sudo docker compose logs \
  --since=5m \
  --tail=100 \
  graphql-api


# Final curl response after the process exits.
cat ~/wavestack-drive-sync.log 2>/dev/null ||
true


