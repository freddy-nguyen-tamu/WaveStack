  -f ~/.ssh/wavestack_oracle_actions \
  -N ''


# Install the GitHub Actions public key on Oracle.
ssh-copy-id \
  -i ~/.ssh/wavestack_oracle_actions.pub \
  -o IdentitiesOnly=yes \
  -o IdentityFile=~/.ssh/wavestack_oracle \
  ubuntu@141.148.156.24


# Print the private deployment key as one base64 line.
# Save it as GitHub secret ORACLE_VM_SSH_PRIVATE_KEY_B64.
base64 -w 0 ~/.ssh/wavestack_oracle_actions
echo


# Required GitHub repository secrets:
# ORACLE_VM_HOST=141.148.156.24
# ORACLE_VM_USER=ubuntu
# ORACLE_VM_SSH_PRIVATE_KEY_B64=<base64 output above>


============================================================
ORACLE TERMINAL: ONE-TIME HOST SETUP
============================================================

# Connect from WSL first:
# ssh -o IdentitiesOnly=yes -i ~/.ssh/wavestack_oracle ubuntu@141.148.156.24


# Update the host and install required packages.
sudo apt update
sudo DEBIAN_FRONTEND=noninteractive apt install -y \
  ca-certificates \
  curl \
  git \
  jq \
  rsync \
  postgresql-client \
  caddy \
  iptables-persistent


# Install Docker if it is not already installed.
if ! command -v docker >/dev/null 2>&1; then
  curl -fsSL https://get.docker.com | sudo sh
fi

sudo systemctl enable --now docker
sudo usermod -aG docker "$USER"


# Create 4 GB swap if no swap exists.
if [ "$(swapon --show --noheadings | wc -l)" -eq 0 ]; then
  sudo fallocate -l 4G /swapfile
  sudo chmod 600 /swapfile
  sudo mkswap /swapfile
  sudo swapon /swapfile

  grep -q '^/swapfile ' /etc/fstab ||
    echo '/swapfile none swap sw 0 0' |
    sudo tee -a /etc/fstab
fi

free -h
swapon --show


# Create application and backup directories.
sudo mkdir -p \
  /srv/wavestack/app \
  /srv/wavestack/data/uploads \
  /srv/wavestack/data/cache \
  /srv/wavestack/data/postgres \
  /srv/wavestack/data/neo4j \
  /srv/wavestack/data/rabbitmq \
  /srv/wavestack/backups \
  /srv/wavestack/failover

sudo chown -R ubuntu:ubuntu /srv/wavestack


============================================================
ORACLE TERMINAL: FIREWALL
============================================================

# OCI Console must also contain stateful ingress rules:
# 0.0.0.0/0 -> TCP destination port 80
# 0.0.0.0/0 -> TCP destination port 443


# Open port 80 before Ubuntu's final REJECT rule.
sudo iptables -C INPUT \
  -p tcp \
  --dport 80 \
  -m conntrack \
  --ctstate NEW \
  -j ACCEPT 2>/dev/null ||
sudo iptables -I INPUT 1 \
  -p tcp \
  --dport 80 \
  -m conntrack \
  --ctstate NEW \
  -j ACCEPT


# Open port 443 before Ubuntu's final REJECT rule.
sudo iptables -C INPUT \
  -p tcp \
  --dport 443 \
  -m conntrack \
  --ctstate NEW \
  -j ACCEPT 2>/dev/null ||
sudo iptables -I INPUT 1 \
  -p tcp \
  --dport 443 \
  -m conntrack \
  --ctstate NEW \
  -j ACCEPT


# Persist firewall rules.
sudo netfilter-persistent save

sudo iptables -L INPUT \
  -n \
  --line-numbers |
head -40


============================================================
ORACLE TERMINAL: CADDY
============================================================

# Write the production reverse-proxy configuration.
sudo tee /etc/caddy/Caddyfile >/dev/null <<'CADDY_EOF'
wavestack.duckdns.org {
    reverse_proxy 127.0.0.1:5173
}

api.wavestack.duckdns.org {
    reverse_proxy 127.0.0.1:3000
}
CADDY_EOF


# Format, validate and start Caddy.
sudo caddy fmt \
  --overwrite \
  /etc/caddy/Caddyfile

sudo caddy validate \
  --config /etc/caddy/Caddyfile

sudo systemctl enable --now caddy
sudo systemctl restart caddy

sudo systemctl status \
  caddy \
  --no-pager

sudo ss -ltnp |
grep -E ':(80|443)\b' || true


# Test Caddy from inside Oracle.
curl -I \
  -H 'Host: wavestack.duckdns.org' \
  http://127.0.0.1

curl -I \
  -H 'Host: api.wavestack.duckdns.org' \
  http://127.0.0.1


# Inspect certificate or proxy errors.
sudo journalctl \
  -u caddy \
  -n 100 \
  --no-pager


============================================================
ORACLE TERMINAL: PRODUCTION DEPLOYMENT
============================================================

cd ~/WaveStack

# Confirm private deployment configuration exists.
test -s .env ||
{
  echo 'ERROR: ~/WaveStack/.env is missing'
  exit 1
}

test -d secrets ||
{
  echo 'ERROR: ~/WaveStack/secrets is missing'
  exit 1
}


# Validate Docker Compose.
sudo docker compose config >/dev/null


# Start PostgreSQL first.
sudo docker compose up -d postgres


# Wait until PostgreSQL is ready.
until sudo docker compose exec -T postgres \
  pg_isready \
  -U wavestack \
  -d wavestack >/dev/null 2>&1
do
  echo 'Waiting for PostgreSQL...'
  sleep 3
done


# Create a database backup before migrations or deployment.
mkdir -p ~/backups

sudo docker compose exec -T postgres \
  pg_dump \
  -U wavestack \
  -d wavestack \
  --clean \
  --if-exists \
  > ~/backups/wavestack-before-deploy-$(date +%Y%m%d-%H%M%S).sql


# Apply the corrected listening-events migration.
sudo docker compose exec -T postgres \
  psql \
  -v ON_ERROR_STOP=1 \
  -U wavestack \
  -d wavestack \
  < infra/postgres/migrations/010_listening_archive_readthrough.sql


# Apply the Drive title-lock migration.
sudo docker compose exec -T postgres \
  psql \
  -v ON_ERROR_STOP=1 \
  -U wavestack \
  -d wavestack \
  < infra/postgres/migrations/011_drive_tracks_title_locked.sql


# Build and start all application containers.
sudo docker compose up \
  --build \
  -d


# Restart GraphQL after the migrations.
sudo docker compose restart graphql-api

sleep 10


# Show all containers, including exited containers.
sudo docker compose ps -a


# Show recent startup logs.
sudo docker compose logs \
  --tail=100 \
  postgres \
  graphql-api \
  frontend \
  neo4j \
  rabbitmq \
  audio-ai-service \
  analytics-service


# Restart the host reverse proxy.
sudo systemctl restart caddy


============================================================
ORACLE TERMINAL: DATABASE VERIFICATION
============================================================

cd ~/WaveStack


# Verify the combined listening-events view.
sudo docker compose exec -T postgres \
  psql \
  -U wavestack \
  -d wavestack \
  -c "
    SELECT to_regclass(
      'public.app_listening_events_combined'
    );
  "


# Verify the title_locked column.
sudo docker compose exec -T postgres \
  psql \
  -U wavestack \
  -d wavestack \
  -c "
    SELECT
      column_name,
      data_type,
      column_default
    FROM information_schema.columns
    WHERE table_name = 'drive_tracks'
      AND column_name = 'title_locked';
  "


# List application users.
sudo docker compose exec -T postgres \
  psql \
  -U wavestack \
  -d wavestack \
  -c "
    SELECT
      id,
      email,
      display_name,
      created_at
    FROM app_users
    ORDER BY created_at;
  "


# Count imported Drive tracks and processing progress.
sudo docker compose exec -T postgres \
  psql \
  -U wavestack \
  -d wavestack \
  -c "
    SELECT
      count(*) AS total_tracks,
      count(*) FILTER (
        WHERE title_locked = true
      ) AS metadata_checked,
      count(*) FILTER (
        WHERE local_thumbnail_url IS NOT NULL
      ) AS thumbnails_cached
    FROM drive_tracks
    WHERE deleted_at IS NULL;
  "


